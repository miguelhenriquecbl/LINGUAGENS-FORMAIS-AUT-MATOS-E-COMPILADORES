digraph afd_completo {
    rankdir=LR;
    nodesep=0.4;
    pad=0.8;
    node [shape=circle, fontname="Arial"];
    edge [fontname="Arial", fontsize=16];

    /* estado invisível pra seta de entrada */
    inicio [shape=none, label=""];

    { rank=same; inicio; q0}

    { rank=same; q1; q2; q4; q5; q6; q7; }

    { rank=same; qTOKEN_EOF; qTOKEN_ERROR; }

    /* Estado Inicial */
    q0 [label="q0\ninicial"];

    /* estados intermediários */
    q1 [label="q1"];
    q2 [label="q2"];
    q3 [label="q3"];
    q4 [label="q4"];
    q5 [label="q5"];
    q6 [label="q6"];
    q7 [label="q7"];
    q8 [label="q8"];
    q9 [label="q9"];
    q10 [label="q10"];
    q11 [label="q11"];
    q12 [label="q12"];

    /* estados finais — círculo duplo */
    node [shape=doublecircle];

    /* Palavras reservadas, Identificador e Tipos Números  */
    qID_KW [label="ID/KW"];
    qNUM_INT [label="NUM_INT"];
    qNUM_REAL [label="NUM_REAL"];

    /* Operadores relacionais */
    qOP_EQ [label="OP_EQ"]; /* = */
    qOP_NE [label="OP_NE"]; /* <> */
    qOP_LT [label="OP_LT"]; /* < */
    qOP_LE [label="OP_LE"]; /* <= */
    qOP_GT [label="OP_GT"]; /* > */
    qOP_GE [label="OP_GE"]; /* >= */

    /* Operadores aritméticos */
    qOP_AD [label="OP_AD"]; /* + */
    qOP_MIN [label="OP_MIN"]; /* - */
    qOP_MUL [label="OP_MUL"]; /* * */
    qOP_DIV [label="OP_DIV"]; /* / */
    qOP_ASS [label="OP_ASS"]; /* := */

    /* Símbolos */
    qSMB_SEM [label="SMB_SEM"]; /* ; */
    qSMB_COM [label="SMB_COM"]; /* , */
    qSMB_OPA [label="SMB_OPA"]; /* ( */
    qSMB_CPA [label="SMB_CPA"]; /* ) */
    qSMB_COL [label="SMB_COL"]; /* : */
    qSMB_DOT [label="SMB_DOT"]; /* . */

    /* Especiais */
    qTOKEN_EOF [shape=doublecircle label="TOKEN_EOF"]; /* Fim do arquivo */
    qTOKEN_ERROR [shape=doublecircle label="TOKEN_ERROR"]; /* Erro léxico */

    /* seta de entrada */
    inicio -> q0;

    /* q0 -> estados intermediários */
    q0 -> qTOKEN_ERROR [label="^[a-zA-Z0-9]\n^[0-9] | ^[+-]\n^: | ^< | ^>\n^\\{ | ^\\. | ^=\n^* | ^/ | ^; | ^,\n^( | ^)"];
    q0 -> qTOKEN_EOF [label="EOF"];

    q0 -> q1 [label="[a-z][A-Z]"];
    q1 -> q1 [label="[a-z][A-Z] | [0-9]"];
    q1 -> qID_KW [label="^[a-zA-Z0-9]\n(lookahead)"];

    q0 -> q2 [label="[0-9]"];
    q2 -> q2 [label="[0-9]"];
    q2 -> q8 [label="Ee"];
    q2 -> qNUM_INT [label="^[0-9] | ^[Ee] | ^\.\n(lookahead)"];

    q2 -> q3 [label="\\. (ponto)"];
    q3 -> q3 [label="[0-9]"];
    q3 -> q8 [label="E e"];
    q3 -> qNUM_REAL [label="^[0-9] | ^[Ee]\n(lookahead)"];

    q0 -> q4 [label=": (dois pontos)"]; 
    q4 -> qOP_ASS [label="= (igual)"]; 
    q4 -> qSMB_COL [label="^=\n(lookahead)"]; 

    q0 -> q5 [label="< (menor que)"]; 
    q5 -> qOP_NE [label="> (maior que)"]; 
    q5 -> qOP_LE [label="= (igual)"]; 
    q5 -> qOP_LT [label="^= | ^>\n(lookahead)"];

    q0 -> q6 [label="> (maior que)"]; 
    q6 -> qOP_GE [label="= (igual)"]; 
    q6 -> qOP_GT [label="^=\n(lookahead)"];

    q0 -> q7 [label="\\{ (abre comentário)"]; 
    q7 -> q7 [label="^\\} | ^EOF"];
    q7 -> q0 [label="\\}\n (fecha comentário sem gerar token)"];
    q7 -> qTOKEN_EOF [label="EOF\n(comentário não fechado)"];

    q0 -> qOP_EQ [label="= (igual)", minlen=3]; 
    q0 -> qOP_MUL [label="* (multiplicação)", minlen=3]; 
    q0 -> qOP_DIV [label="/ (divisão)", minlen=3]; 

    q0 -> qSMB_SEM [label="; (ponto e vírgula)", minlen=3]; 
    q0 -> qSMB_COM [label=", (vírgula)", minlen=3]; 
    q0 -> qSMB_OPA [label="( (abre parêntese)", minlen=3]; 
    q0 -> qSMB_CPA [label=") (fecha parêntese)", minlen=3]; 
    q0 -> qSMB_DOT [label="\\. (ponto)", minlen=3];

    q0 -> q11 [label="+ (adição)"]; 
    q11 -> q2 [label="[0-9]"]; 
    q11 -> qOP_AD [label="^[0-9]\n(lookahead)"];

    q0 -> q12 [label="- (subtração)"]; 
    q12 -> q2 [label="[0-9]"]
    q12 -> qOP_MIN [label="^[0-9]\n(lookahead)"]

    q8 -> q9 [label="+ | -\n(sinal)"]
    q8 -> q10 [label="[0-9]"]
    q9 -> q10 [label="[0-9]"]
    q10 -> q10 [label="[0-9]"]
    q8 -> qTOKEN_ERROR [label="^[0-9] | ^[+-]\n(lookahead)"];
    q9 -> qTOKEN_ERROR [label="^[0-9]\n(lookahead)"];
    q10 -> qNUM_REAL [label="^[0-9]\n(lookahead)"];
}