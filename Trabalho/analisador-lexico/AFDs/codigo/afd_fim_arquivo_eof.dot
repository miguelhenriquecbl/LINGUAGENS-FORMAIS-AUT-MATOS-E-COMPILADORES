digraph afd_fim_arquivo_eof {
    rankdir=LR;
    nodesep=0.4;
    pad=0.8;
    node [shape=circle, fontname="Arial"];
    edge [fontname="Arial", fontsize=16];

    /* estado invisível pra seta de entrada */
    inicio [shape=none, label=""];

    /* Estado Inicial */
    q0 [label="q0\ninicial"];

    /* Especiais */
    qTOKEN_EOF [shape=doublecircle label="TOKEN_EOF"]; /* Fim do arquivo */

    /* seta de entrada */
    inicio -> q0;

    /* q0 -> estados intermediários */
    q0 -> qTOKEN_EOF [label="EOF"];

}